########################################################################
# CATEST — 全局分布式 RAG 平台配置模板
# 指引: 1. cp .env.example .env  2. 填写必填项(数据库、JWT)  3. 启动基础设施
########################################################################

# ─────────────── 系统工具链 / Toolchain (Windows 开发必备) ───────────────
# 编译 rdkafka 和 sqlx (TLS) 时需要的外部依赖路径
# OPENSSL_DIR=C:\Program Files\OpenSSL-Win64
# OPENSSL_LIBS=libssl:libcrypto

# ─────────────── 功能开关 / Feature Toggles ──────────────────────────
# 是否启用本地大模型 (Ollama) 推理
ENABLE_OLLAMA=false
# 是否启用邮件通知服务
ENABLE_SMTP=false
# 是否在启动时自动同步知识图谱 (Neo4j)
AUTO_SYNC_GRAPH=true

# ─────────────── 基础设施 / Infrastructure Ports ──────────────────────
# 端口建议保持默认，除非有冲突
PORT_POSTGRES=35432
PORT_KAFKA=39092
PORT_NEO4J_HTTP=37474
PORT_NEO4J_BOLT=37687
PORT_QDRANT_HTTP=36334
PORT_QDRANT_GRPC=36333
PORT_ARROYO_UI=35115

# ─────────────── 数据库连接串 / Database URLs ─────────────────────────
# 格式: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://catest:password@localhost:35432/catest_gateway
INGESTION_DATABASE_URL=postgres://catest:password@localhost:35432/catest_ingestion
PARSER_DATABASE_URL=postgres://catest:password@localhost:35432/catest_parser

# ─────────────── Kafka 消息队列 ────────────────────────────────────────
KAFKA_BROKERS=localhost:39092
KAFKA_GROUP_ID=catest-consumer-group

# ─────────────── 向量与图检索 / RAG Storage ──────────────────────────
NEO4J_URI=bolt://localhost:37687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password            # 需与 docker-compose 中 NEO4J_AUTH 保持一致

QDRANT_URL=http://localhost:36334
QDRANT_API_KEY=password            # Qdrant 身份验证密钥

# ─────────────── 共享存储 / Shared Storage (NAS Mount) ────────────────
# 必须在所有服务中挂载同一个 NAS 路径 (或本地对应目录)
# Docker 宿主机对应路径 (Windows UNC 或 Linux 路径)
HOST_STORAGE_PATH=您的存储路径
# Docker 内部统一路径: /data/catest
STORAGE_ROOT=/data/catest

# ─────────────── JWT & 身份校验 / Security ───────────────────────────

# 生成 32 位随机密钥: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_HS256_SECRET=REQUIRED_FILL_IN_YOUR_SECRET_HERE

# ─────────────── 邮件 / SMTP (功能未启用时可不填) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASS=app_specific_password

# ─────────────── AI 模型 / Models Configuration ──────────────────────
# 嵌入模型 (由 crates/embedding 使用)
EMBED_MODEL_NAME=intfloat/multilingual-e5-small
EMBED_VECTOR_DIM=384                # 与 e5-small 匹配

# 重排序模型
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# ─────────────── Ollama (本地 Llama/Qwen 服务) ───────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─────────────── 开发者配置 / Dev Context ────────────────────────────
DEMO_PROJECT_ID=default-catest-project
DEMO_REPO_URL=https://github.com/UlyssesLeoLee/CATEST.git