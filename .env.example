########################################################################
# CATEST — 全局配置模板   (.env.example → 复制为 .env 后填写真实值)
# 参与开发前: cp .env.example .env
########################################################################

# ─────────────── 基础设施 / Infrastructure Ports ──────────────────────
POSTGRES_PORT=35432
KAFKA_PORT=39092
KAFKA_BROKER=localhost:39092       # 宿主机访问 Kafka 的地址

NEO4J_HTTP_PORT=37474
NEO4J_BOLT_PORT=37687
NEO4J_URI=bolt://localhost:37687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password            # 修改 docker-compose 中 NEO4J_AUTH 后保持一致

QDRANT_HTTP_PORT=36334
QDRANT_GRPC_PORT=36333
QDRANT_URL=http://localhost:36334

ARROYO_UI_PORT=35115

# ─────────────── 数据库连接串 / Database URLs ─────────────────────────
DATABASE_URL=postgres://catest:password@localhost:35432/catest_gateway
INGESTION_DATABASE_URL=postgres://catest:password@localhost:35432/catest_ingestion
PARSER_DATABASE_URL=postgres://catest:password@localhost:35432/catest_parser

# ─────────────── Rust 微服务端口 / Microservice Ports ─────────────────
GATEWAY_PORT=33080
REVIEW_PORT=33081

# ─────────────── Next.js 前端 / Frontend ─────────────────────────────
FRONTEND_PORT=33000

# ─────────────── 邮件 / SMTP ──────────────────────────────────────────
# Gmail 应用专用密码: 账号 → 安全 → 两步验证 → 应用专用密码
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=你的Gmail地址@gmail.com
SMTP_PASS=Gmail应用专用密码（16位）

# ─────────────── JWT / Session ────────────────────────────────────────
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_HS256_SECRET=

# ─────────────── 本地小模型 / Local Small Models ──────────────────────
# 嵌入模型 → Qdrant 向量存储
EMBED_MODEL_NAME=intfloat/multilingual-e5-small
EMBED_VECTOR_DIM=384                # multilingual-e5-small 输出维度

# 重排序模型 → 辅助 Neo4j 实体排序
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# 如使用独立推理服务 (如 text-embeddings-inference)，取消注释:
# EMBED_API_URL=http://localhost:33080/embed
# RERANKER_API_URL=http://localhost:33081/rerank

# ─────────────── Ollama (可选，本地大模型) ────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ─────────────── Demo / 开发用固定数据 ───────────────────────────────
DEMO_PROJECT_ID=
DEMO_REPO_URL=https://github.com/UlyssesLeoLee/CATEST.git