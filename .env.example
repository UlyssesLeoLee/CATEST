########################################################################
# CATEST — 全局配置文件模板 (Unified 3XXXX Ports & Secrets)
# 指引: 1. cp .env.example .env  2. 填写必填项(数据库、JWT)  3. 启动基础设施
# 所有端口、密钥、模型路径均在此集中管理。
########################################################################

# ─────────────── 基础设施 / Infrastructure Ports ──────────────────────
# All external LoadBalancer ports must start with 3

# Next.js Micro-Frontends
NEXT_PUBLIC_PORT_WEB_BASE=33000
NEXT_PUBLIC_PORT_WEB_WORKSPACE=33001
NEXT_PUBLIC_PORT_WEB_RAG=33002
NEXT_PUBLIC_PORT_WEB_REVIEW=33003

# Application Services
NEXT_PUBLIC_PORT_GATEWAY=33080
NEXT_PUBLIC_PORT_REVIEW_SERVICE=33081
ENVOY_GATEWAY_PORT=33088

# PostgreSQL (LoadBalancer External Port)
POSTGRES_PORT=34321
POSTGRES_USER=catest
POSTGRES_PASSWORD=password

# Adminer (PostgreSQL Web UI)
ADMINER_PORT=38080

# Kafka
KAFKA_PORT=39092
KAFKA_BROKER=localhost:39092

# Neo4j
NEO4J_HTTP_PORT=37474
NEO4J_BOLT_PORT=37687
NEO4J_URI=bolt://localhost:37687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Qdrant
QDRANT_HTTP_PORT=36334
QDRANT_GRPC_PORT=36333
QDRANT_API_KEY=password
QDRANT_URL=http://localhost:36334

# Arroyo
ARROYO_UI_PORT=35115

# ─────────────── 数据库连接串 / Database URLs ─────────────────────────
# 使用变量引用，端口与 POSTGRES_PORT 保持一致
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/catest_gateway
INGESTION_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/catest_ingestion
PARSER_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/catest_parser

# ─────────────── 邮件 / SMTP ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ─────────────── JWT / Session ────────────────────────────────────────
# 生成 32 位随机密钥: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_HS256_SECRET=REQUIRED_FILL_IN_YOUR_SECRET_HERE

# ─────────────── 本地小模型 / Local Small Models ──────────────────────
EMBED_MODEL_NAME=intfloat/multilingual-e5-small
EMBED_VECTOR_DIM=384
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# ─────────────── 共享存储 / Shared Storage (NAS Mount) ────────────────
# Docker 宿主机对应路径 (Windows UNC 或 Linux 路径)
HOST_STORAGE_PATH=your-storage-path
# Docker 内部统一路径
STORAGE_ROOT=/data/catest

# ─────────────── AI Code Review / 代码审查AI ─────────────────────────
# Compatible with any OpenAI-compatible API (OpenAI, Anthropic via proxy, local LLM, etc.)
CATEST_AI_API_KEY=sk-your-api-key-here
CATEST_AI_BASE_URL=https://api.openai.com/v1
CATEST_AI_MODEL=gpt-4o-mini

# ─────────────── Demo / 开发用固定数据 ───────────────────────────────
DEMO_PROJECT_ID=
DEMO_REPO_URL=https://github.com/UlyssesLeoLee/CATEST.git
